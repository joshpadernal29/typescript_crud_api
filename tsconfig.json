{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "types": [
      "node",
      "jest"
    ], // <--- ADD "jest" HERE
    "lib": [
      "ES2020"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    /* Strictness & Compatibility */
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    /* Path Aliases */
    "baseUrl": "./src",
    "paths": {
      "_helpers/*": [
        "_helpers/*"
      ],
      "_middleware/*": [
        "_middleware/*"
      ],
      "users/*": [
        "users/*"
      ]
    },
    "ignoreDeprecations": "6.0", // to silence baseUrlDeprecation error
    "verbatimModuleSyntax": false,
    /* These were in your text but NOT the image - commenting them out */
    // "noUncheckedIndexedAccess": true,
    // "exactOptionalPropertyTypes": true,
    // "isolatedModules": true,
    // "noUncheckedSideEffectImports": true,
    // "moduleDetection": "force",
    /* Documentation/Debug settings from your text */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}